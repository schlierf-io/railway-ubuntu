{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildCommand": "metal"
  },
  "deploy": {
    "name": "dev-container",
    "startCommand": "/usr/local/bin/entrypoint.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "region": "eu-west"
  },
  "volumes": {
    "data": {
      "mount": "/data",
      "sizeGB": 100
    }
  }
}
